# -------------------------
# Terraform
# -------------------------
# Local .terraform directories
**/.terraform/*
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.plan

# -------------------------
# Helm
# -------------------------
# Chart build output
charts/
helm-charts/
*.tgz

# Helm release metadata
.release/

# -------------------------
# Kubernetes
# -------------------------
# Kubeconfig files
kubeconfig
.kube/
*.kubeconfig

# -------------------------
# Cloud Provider Credentials
# -------------------------
# Google Cloud
application_default_credentials.json
gcloud-service-key.json
*.pem
*.key.json

# AWS (if ever used)
.aws/

# Azure (if ever used)
.azure/

# -------------------------
# IDE / Editor Files
# -------------------------
# VS Code
.vscode/
.history/

# IntelliJ / JetBrains
.idea/
*.iml

# -------------------------
# OS Files
# -------------------------
# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Linux
*~
.gitignore